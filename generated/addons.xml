<?xml version='1.0' encoding='utf-8'?>
<addons><addon id="plugin.program.autocleaner" version="1.0.0" name="[COLOR lightgreen]Auto Cleaner[/COLOR]" provider-name="vale44">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.addon.metadata">
        <summary>Auto Cleaner for Kodi</summary>
        <description>Cleans up thumbnails, cache, and packages periodically to keep Kodi running smoothly.</description>
        <platform>all</platform>
        <license>GPL v2.0</license>
        <source>https://github.com/vale44/plugin.program.autocleaner</source>
    </extension>
    <extension point="xbmc.service" library="service.py">
        <provides>program</provides>
    </extension>
    <extension point="xbmc.python.script" library="default.py">
        <provides>program</provides>
    </extension>
</addon><addon id="plugin.program.weboscorecleaner" version="1.0.0" name="[COLOR orange]WebOS Core Cleaner[/COLOR]" provider-name="vale44">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.addon.metadata">
        <summary>WebOS Core Cleaner for Kodi</summary>
        <description>Cleans .core files from Kodi WebOS TVs which get generated after crashes, slowing down your system and filling up your storage space, sometimes significantly. These core files can be found in the location: /media/developer/apps/usr/palm/applications/org.xbmc.kodi and are automatically deleted to keep your system running smoothly.</description>
        <platform>all</platform>
        <license>GPL v2.0</license>
        <source>https://github.com/vale44/plugin.program.weboscorecleaner</source>
    </extension>
    <extension point="xbmc.service" library="service.py">
        <provides>program</provides>
    </extension>
    <extension point="xbmc.python.script" library="default.py">
        <provides>program</provides>
    </extension>
